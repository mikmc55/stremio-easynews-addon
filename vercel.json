{
  "version": 2,
  "builds": [
    {
      "src": "packages/api/dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "packages/api/dist/index.js"
    }
  ],
  "installCommand": "npm install --workspaces",
  "outputDirectory": "packages/api/dist"  // Specify output directory if needed
}
